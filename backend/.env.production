# Production Environment Configuration for EC2
# Copy this to .env on your EC2 server

# Server
PORT=5000
NODE_ENV=production

# MongoDB (if using)
MONGODB_URI=mongodb://localhost:27017/network-monitor

# Prometheus - IMPORTANT: Use external IP or localhost if on same server
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_TIMEOUT=30000

# Grafana - IMPORTANT: Use external IP or localhost if on same server  
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=glsa_TLiJx5EmwvFbpaI035273T9HlIKe4UbN_42cc8698

# Frontend URL (for CORS) - Can be comma-separated for multiple origins
# For local development use: http://localhost:3001
# For production frontend use: http://51.20.52.19:4173 (or your frontend URL)
FRONTEND_URL=http://localhost:3001,http://localhost:3002,http://51.20.52.19:4173,http://51.20.52.19:3001
